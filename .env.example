# ─────────────────────────────────────────────
#  Telegram AI Chatbot — Environment Variables
# ─────────────────────────────────────────────

# Your Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Key (from platform.openai.com)
OPENAI_API_KEY=your_openai_api_key_here

# Comma-separated Telegram user IDs that are admins
# Example: ADMIN_IDS=123456789,987654321
ADMIN_IDS=your_telegram_user_id_here

# OpenAI model to use
OPENAI_MODEL=gpt-4o-mini

# Max conversation history messages to keep per user (per side)
MAX_HISTORY=10

# User cooldown in seconds (anti-spam)
COOLDOWN_SECONDS=5

# Max requests per minute per user
RATE_LIMIT_PER_MINUTE=15

# SQLite database path (leave as default or change)
DATABASE_URL=sqlite:///bot/data/chatbot.db

# Port for the web server (Render sets this automatically)
PORT=8000

# System prompt for the AI
SYSTEM_PROMPT=You are a helpful, friendly, and concise AI assistant. Answer clearly and accurately.

